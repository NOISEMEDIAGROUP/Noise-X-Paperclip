{
  "name": "@paperclipai/server",
  "version": "0.3.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "cross-env PAPERCLIP_MIGRATION_PROMPT=never tsx watch --ignore ../ui/node_modules --ignore ../ui/.vite --ignore ../ui/dist src/index.ts",
    "prepare:ui-dist": "bash ../scripts/prepare-server-ui-dist.sh",
    "build": "tsc",
    "prepack": "pnpm run prepare:ui-dist",
    "postpack": "rm -rf ui-dist",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@paperclipai/adapter-claude-local": "workspace:*",
    "@paperclipai/adapter-codex-local": "workspace:*",
    "@paperclipai/adapter-cursor-local": "workspace:*",
    "@paperclipai/adapter-gemini-local": "workspace:*",
    "@paperclipai/adapter-openclaw-gateway": "workspace:*",
    "@paperclipai/adapter-opencode-local": "workspace:*",
    "@paperclipai/adapter-pi-local": "workspace:*",
    "@paperclipai/adapter-utils": "workspace:*",
    "@paperclipai/db": "workspace:*",
    "@paperclipai/plugin-sdk": "workspace:*",
    "@paperclipai/shared": "workspace:*",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-auth": "1.4.18",
    "chokidar": "^5.0.0",
    "detect-port": "^2.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.4",
    "embedded-postgres": "18.1.0-beta.16",
    "express": "^5.2.1",
    "hermes-paperclip-adapter": "0.1.1",
    "multer": "^2.1.1",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
