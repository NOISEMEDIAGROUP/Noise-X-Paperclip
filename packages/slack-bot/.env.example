# Optional config file (default: ./slack-codex.config.json)
SLACK_CODEX_CONFIG=

# Slack auth + mode
SLACK_MODE=socket
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=
SLACK_APP_ID=
SLACK_WEBHOOK_PATH=/slack/events
SLACK_PORT=3000

# DM / channel policy
SLACK_DM_ENABLED=true
SLACK_DM_POLICY=pairing
SLACK_ALLOW_FROM=
SLACK_DM_GROUP_ENABLED=false
SLACK_DM_GROUP_CHANNELS=
SLACK_GROUP_POLICY=allowlist
SLACK_ALLOWED_CHANNELS=
SLACK_DANGEROUS_NAME_MATCHING=false

# Mention + room behavior
SLACK_REQUIRE_MENTION_DEFAULT=true
SLACK_MENTION_PATTERNS=
SLACK_ALLOW_BOTS=false

# Threading + sessions
SLACK_REPLY_TO_MODE=off
SLACK_REPLY_TO_MODE_DIRECT=
SLACK_REPLY_TO_MODE_GROUP=
SLACK_REPLY_TO_MODE_CHANNEL=
SLACK_THREAD_HISTORY_SCOPE=thread
SLACK_THREAD_INHERIT_PARENT=false
SLACK_THREAD_INITIAL_HISTORY_LIMIT=20
SLACK_INBOUND_DEBOUNCE_MS=800

# Delivery
SLACK_TEXT_CHUNK_LIMIT=4000
SLACK_CHUNK_MODE=length
SLACK_MEDIA_MAX_MB=20
SLACK_STREAMING=partial
SLACK_NATIVE_STREAMING=true
SLACK_ACK_REACTION=eyes
SLACK_REMOVE_ACK_AFTER_REPLY=false

# Commands + actions
SLACK_COMMANDS_NATIVE=true
SLACK_SLASH_COMMAND_ENABLED=true
SLACK_SLASH_COMMAND_NAME=openclaw
SLACK_SLASH_COMMAND_EPHEMERAL=true
SLACK_ACTIONS_MESSAGES=true
SLACK_ACTIONS_REACTIONS=true
SLACK_ACTIONS_PINS=true
SLACK_ACTIONS_MEMBER_INFO=true
SLACK_ACTIONS_EMOJI_LIST=true

# Optional per-channel JSON overrides (same shape as OpenClaw channels.slack.channels)
SLACK_CHANNELS_JSON=

# Config migration on channel_id_changed
SLACK_CONFIG_WRITES=false

# Codex (OAuth via local codex login)
CODEX_MODEL=gpt-5.3-codex
CODEX_PROFILE=
CODEX_WORKDIR=../..
CODEX_SANDBOX=workspace-write
CODEX_ADDITIONAL_WRITABLE_DIRS=
CODEX_TIMEOUT_MS=1800000
CODEX_SYSTEM_PROMPT=You are Codex. Reply concisely and helpfully.

# Paperclip task bridge (local_trusted loopback v1)
PAPERCLIP_ENABLED=false
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_COMPANY_ID=
PAPERCLIP_TASK_PREFIX=task:
PAPERCLIP_TRIGGER_MENTIONS=@paperclip
PAPERCLIP_AGENT_MAPPINGS_JSON={}
PAPERCLIP_PROJECT_MAPPINGS_JSON={}
PAPERCLIP_SYNC_REPLIES=mention_only
PAPERCLIP_NOTIFICATION_MODE=high_signal

# Runtime
DATA_DIR=./data
LOG_LEVEL=info
